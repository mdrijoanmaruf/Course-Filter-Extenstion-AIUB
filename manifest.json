{
  "manifest_version": 3,
  "name": "AIUB Portal+",
  "version": "2.0",
  "description": "Comprehensive enhancement suite for the AIUB Student Portal — advanced course filtering, clash detection, grade visualization, smart schedule display, and UI improvements across all portal pages.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://portal.aiub.edu/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://portal.aiub.edu/Student*"],
      "js": ["Shared/contentBridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://portal.aiub.edu/Student*"],
      "js": ["Shared/Sidebar.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Section/Offered*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://portal.aiub.edu/Student",
        "https://portal.aiub.edu/Student/",
        "https://portal.aiub.edu/Student/Home/*"
      ],
      "js": ["Home/Intro.js", "Home/ClassSchedule.js", "Home/Registration.js"],
      "css": ["Home/ClassSchedule.css", "Home/Registration.css", "Home/Intro.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Course?*"],
      "js": ["Academic/CourseAndResults.js"],
      "css": ["Academic/CourseAndResults.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Curriculum*"],
      "js": ["Academic/MkCurriculumn.js"],
      "css": ["Academic/MkCurriculumn.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Accounts*"],
      "js": ["Academic/Financials.js"],
      "css": ["Academic/Financials.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Adrop/DropApplication*"],
      "js": ["Academic/DropApplication.js"],
      "css": ["Academic/DropApplication.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Registration?*"],
      "js": ["Academic/Registration.js"],
      "css": ["Academic/Registration.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/GradeReport/ByCurriculum*"],
      "js": ["Grade/carriculum_grade_report.js"],
      "css": ["Grade/carriculum_grade_report.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/GradeReport/BySemester*"],
      "js": ["Grade/carriculum_grade_semester.js"],
      "css": ["Grade/carriculum_grade_semester.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "aiub.jpg",
      "48": "aiub.jpg",
      "128": "aiub.jpg"
    }
  },
  "icons": {
    "16": "aiub.jpg",
    "48": "aiub.jpg",
    "128": "aiub.jpg"
  },
  "web_accessible_resources": [
    {
      "resources": ["Home/Registration.css", "Home/Intro.css", "Shared/Sidebar.css", "Shared/contentBridge.js"],
      "matches": ["https://portal.aiub.edu/*"]
    }
  ]
}
