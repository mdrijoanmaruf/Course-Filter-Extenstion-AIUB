{
  "manifest_version": 3,
  "name": "AIUB Course Filter",
  "version": "1.0",
  "description": "Advanced filtering for AIUB Portal Offered Courses — filter by status, seat availability, day, and time slot",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://portal.aiub.edu/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://portal.aiub.edu/Student/Section/Offered*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Course?*"],
      "js": ["Academic/CourseAndResults.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Curriculum*"],
      "js": ["Academic/MkCurriculumn.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Adrop/DropApplication*"],
      "js": ["Academic/DropApplication.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Registration?*"],
      "js": ["Academic/Registration.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/GradeReport/ByCurriculum*"],
      "js": ["Grade/carriculum_grade_report.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/GradeReport/BySemester*"],
      "js": ["Grade/carriculum_grade_semester.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "aiub.jpg",
      "48": "aiub.jpg",
      "128": "aiub.jpg"
    }
  },
  "icons": {
    "16": "aiub.jpg",
    "48": "aiub.jpg",
    "128": "aiub.jpg"
  }
}
